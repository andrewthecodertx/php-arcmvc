# Application settings
APP_NAME=Arc
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Database settings
# DB_CONNECTION should match a key in config/database.php connections
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=arc
# Use a dedicated app user, not root
DB_USERNAME=app_user
DB_PASSWORD=